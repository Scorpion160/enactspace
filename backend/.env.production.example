APP_NAME=EnactSpace
APP_ENV=production
APP_DEBUG=false
APP_VERSION=1.1.0

# Database
DATABASE_URL=postgresql+psycopg://enactspace_user:CHANGE_ME@127.0.0.1:5432/enactspace

# Security
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
JWT_SECRET_KEY=CHANGE_ME_LONG_RANDOM_JWT_SECRET
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENABLE_SEED=false

# Public URLs
CORS_ORIGINS="https://app.enactspace.example.com,https://admin.enactspace.example.com"
PUBLIC_API_BASE_URL="https://api.enactspace.example.com"
FILE_STORAGE_PATH=/var/lib/enactspace/uploads
AUTO_CREATE_TABLES=false

# Email notifications
EMAIL_ENABLED=false
NOTIFICATION_EMAIL_ENABLED=false
NOTIFICATION_EMAIL_FROM=noreply@enactspace.example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true

# Push notifications
PUSH_ENABLED=false
NOTIFICATION_PUSH_ENABLED=false
FCM_SERVER_KEY=

# Payments
PAYMENT_PROVIDER_ENABLED=false
PAYMENT_PROVIDER=manual_proof
PAYMENT_WEBHOOK_SECRET=
MOBILE_MONEY_ENABLED=false
MOBILE_MONEY_PROVIDER=paydunya
PAYDUNYA_MODE=test
PAYDUNYA_MASTER_KEY=
PAYDUNYA_PUBLIC_KEY=
PAYDUNYA_PRIVATE_KEY=
PAYDUNYA_TOKEN=
PAYDUNYA_CALLBACK_URL="https://API_VPS/api/payments/paydunya/ipn"
PAYDUNYA_RETURN_URL="https://APP_OU_WEB/payment/return"
PAYDUNYA_CANCEL_URL="https://APP_OU_WEB/payment/cancel"
PAYDUNYA_ALLOWED_CHANNELS="wave-senegal,orange-money-senegal"
PAYDUNYA_TIMEOUT_SECONDS=15
PAYMENT_CURRENCY=XOF
PAYMENT_TRANSACTION_TTL_MINUTES=30
PAYMENT_RECONCILIATION_ENABLED=true

# QR attendance
ATTENDANCE_QR_ENABLED=true
ATTENDANCE_QR_SECRET=CHANGE_ME
ATTENDANCE_QR_TTL_SECONDS=60
ATTENDANCE_QR_ROTATION_SECONDS=45
ATTENDANCE_LATE_GRACE_MINUTES=10
ATTENDANCE_QR_RATE_LIMIT_PER_MINUTE=10
ATTENDANCE_QR_REQUIRE_MANUAL_CONFIRMATION=false
ATTENDANCE_QR_REQUIRE_SESSION_PIN=false
ATTENDANCE_QR_REQUIRE_LOCATION_CHECK=false

# NFC attendance
ATTENDANCE_NFC_ENABLED=true
ATTENDANCE_NFC_HASH_SECRET=CHANGE_ME
ATTENDANCE_NFC_RATE_LIMIT_PER_MINUTE=30
